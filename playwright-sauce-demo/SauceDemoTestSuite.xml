<suite name="Regression Suite">
    <listeners>
        <listener class-name="com.codinglair.taf.core.reporting.impl.allure.AllureListener"/>
    </listeners>
    <test name="SauceDemo Functional Tests">
        <parameter name="controllerClass" value="com.codinglair.taf.core.controller.impl.PlaywrightController"/>
        <classes>
            <class name="com.codinglair.taf.sauce.tests.functional.SauceDemoLoginTest"/>
        </classes>
    </test>

    <test name="SauceDemo Acceptance Tests">
        <parameter name="controllerClass" value="com.taf.kafka.KafkaController"/>
        <classes>
            <class name="com.codinglair.taf.sauce.bdd.SauceDemoRunner"/>
        </classes>
    </test>
</suite>